      - lambda: 'id(ble_server).set_manufacturer_data(id(end_pkt));'
      - delay: 300ms
      - lambda: 'id(ble_server).set_manufacturer_data({});'
      - script.execute: clear_broadcast

# ========== 网络看门狗 ==========
interval:
  - interval: 60s
    then:
      - lambda: |-
          static uint32_t last_ok = 0;
          if (network::is_connected()) {
            last_ok = millis();
          } else if (millis() - last_ok > 180000) {
            ESP_LOGW("Watchdog", "Network lost >3min, rebooting...");
            delay(100);
            App.reboot();
          }
