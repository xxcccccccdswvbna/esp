esphome:
  name: midea-ble-proxy
  friendly_name: Midea BLE Proxy
  # ✅ 启动延迟：让射频初始化完成后再工作
  on_boot:
    - priority: 600
      then:
        - delay: 2s

esp32:
  board: esp32-s3-devkitc-1
  framework:
    type: esp-idf
    version: recommended
    sdkconfig_options:
      CONFIG_BT_BLE_DYNAMIC_ENV_MEMORY: "y"
      CONFIG_FREERTOS_HZ: "1000"

logger:
  level: INFO  # ← 代理模式下无需调试日志，减少输出
  logs:
    esp32_ble: WARN
    bluetooth_proxy: INFO

api:
  encryption:
    key: "4jGVSQw9/v+e8QCB/CSQIwGFcWS3Opo4oHSRbkq41RI="
  reboot_timeout: 1h

ota:
  platform: esphome
  password: "chen1122"

wifi:
  ssid: "CC"
  password: "chen1122"
  power_save_mode: none

# ✅ 核心：启用蓝牙代理（让 HA 接管扫描和解析）
bluetooth_proxy:
  active: true
  cache_services: true  # 缓存服务，提升响应速度

# ✅ 基础蓝牙声明（代理模式必需）
esp32_ble:
  io_capability: none

# ✅ 保留广播发送功能（用于控制 Dev1/Dev2）
esp32_ble_server:
  id: ble_server
  manufacturer_data: []

# ========== 全局变量 (仅用于控制防冲突) ==========
globals:
  - id: last_cmd_time
    type: uint32_t
    initial_value: '0'
  - id: cmd_pkt
    type: std::vector<uint8_t>
    initial_value: 'std::vector<uint8_t>{}'
  - id: end_pkt
    type: std::vector<uint8_t>
    initial_value: 'std::vector<uint8_t>{}'
  - id: is_sending
    type: bool
    initial_value: 'false'

# ========== 清空广播脚本 ==========
script:
  - id: clear_broadcast
    then:
      - delay: 500ms
      - lambda: |-
          std::vector<uint8_t> empty(26, 0x00);
          id(ble_server).set_manufacturer_data(empty);
      - delay: 500ms
      - globals.set: {id: is_sending, value: 'false'}

# ========== 保留控制功能：滑块 & 按钮 ==========
