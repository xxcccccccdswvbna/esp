# 🟦 Dev1 开关按钮
button:
  - platform: template
    name: "Dev1 Light Toggle"
    icon: mdi:lightbulb
    on_press:
      - globals.set: {id: is_sending, value: 'true'}
      - lambda: |-
          if (millis() - id(last_cmd_time) < 300) return; id(last_cmd_time) = millis();
          id(cmd_pkt) = {0x11,0x4D,0x19,0x15,0x48,0x80,0x27,0x70,0x00,0x00,0x01,0xA6,0xF0,0x86,0x80,0x97,0x27,0x27,0x70,0x70,0x00,0x5F,0xC8,0x6F,0xB8,0x40};
